{
  "extends": "@vue/tsconfig/tsconfig.dom.json",
  "include": [
    "env.d.ts",
    "src/**/*",
    "src/**/*.ts",
    "src/**/*.d.ts",
    "src/**/*.vue",
    "src/types/defineCustomElement.ts",
    "wcds.shim.d.ts"
, "src/defineCustomElement.ts"  ],
  "exclude": ["src/**/__tests__/*", "eslint.config.js"],
  "compilerOptions": {
    "composite": true,
    "noEmit": false,
    "tsBuildInfoFile": "./node_modules/.tmp/tsconfig.app.tsbuildinfo",
    "allowImportingTsExtensions": false,
    "paths": {
      "@/*": ["./src/*"]
    }
  }
}
